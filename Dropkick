local SpeedVFX = EffectsFolder:FindFirstChild("SpeedVFX")
local SpeedVFX2 = EffectsFolder:FindFirstChild("SpeedVFX2")

-- ==================== KEYFRAME PLAYER ====================
local EasingStyleMap = {
	[Enum.PoseEasingStyle.Linear]   = Enum.EasingStyle.Linear,
	[Enum.PoseEasingStyle.Bounce]   = Enum.EasingStyle.Bounce,
	[Enum.PoseEasingStyle.Cubic]    = Enum.EasingStyle.Cubic,
	[Enum.PoseEasingStyle.Elastic]  = Enum.EasingStyle.Elastic,
	[Enum.PoseEasingStyle.Constant] = Enum.EasingStyle.Linear,
}

local EasingDirectionMap = {
	[Enum.PoseEasingDirection.In]    = Enum.EasingDirection.In,
	[Enum.PoseEasingDirection.Out]   = Enum.EasingDirection.Out,
	[Enum.PoseEasingDirection.InOut] = Enum.EasingDirection.InOut,
}

local function PlayKeyframeSequence(Model, KeyframeSequence, SpeedMult)
	SpeedMult = SpeedMult or 1

	local keyframes = {}
	for _, kf in ipairs(KeyframeSequence:GetKeyframes()) do
		table.insert(keyframes, {Time = kf.Time, KF = kf})
	end
	table.sort(keyframes, function(a,b) return a.Time < b.Time end)

	if #keyframes == 0 then 
		return { Length = 0, Stop = function() end, Play = function() end }
	end

	local jointData = {}
	local motorMap = {}
	local boneMap = {}

	local function ResolveJoint(pose)
		local name = pose.Name
		if motorMap[name] then return motorMap[name], "Motor6D" end
		if boneMap[name] then return boneMap[name], "Bone" end

		for _, v in ipairs(Model:GetDescendants()) do
			if v:IsA("Motor6D") and v.Part1 and v.Part1.Name == name then
				motorMap[name] = v
				return v, "Motor6D"
			elseif v:IsA("Bone") and v.Name == name then
				boneMap[name] = v
				return v, "Bone"
			end
		end
		return nil, nil
	end

	for _, entry in ipairs(keyframes) do
		for _, pose in ipairs(entry.KF:GetDescendants()) do
			if pose:IsA("Pose") and pose.Weight > 0 then
				local joint, jtype = ResolveJoint(pose)
				if joint then
					if not jointData[pose.Name] then jointData[pose.Name] = {} end
					table.insert(jointData[pose.Name], {
						time = entry.Time,
						cframe = pose.CFrame,
						style = pose.EasingStyle,
						dir = pose.EasingDirection,
						joint = joint,
						jtype = jtype
					})
				end
			end
		end
	end

	local totalLength = keyframes[#keyframes].Time / SpeedMult
	local isPlaying = true
	local startTime = os.clock()
	local conn

	conn = RunService.Heartbeat:Connect(function()
		if not isPlaying or not Model or not Model.Parent then
			if conn then conn:Disconnect() end
			return
		end

		local elapsed = (os.clock() - startTime) * SpeedMult
		local timePos = elapsed % totalLength

		for jointName, poses in pairs(jointData) do
			if #poses < 1 then continue end

			local lastPose = poses[1]
			local nextPose = poses[1]

			for i = 1, #poses - 1 do
				if timePos >= poses[i].time and timePos < poses[i+1].time then
					lastPose = poses[i]
					nextPose = poses[i+1]
					break
				end
			end

			if timePos >= poses[#poses].time then
				lastPose = poses[#poses]
				nextPose = poses[#poses]
			end

			local alpha = 0
			if nextPose.time > lastPose.time then
				alpha = (timePos - lastPose.time) / (nextPose.time - lastPose.time)
			end

			local easedAlpha = TweenService:GetValue(alpha,
				EasingStyleMap[nextPose.style] or Enum.EasingStyle.Linear,
				EasingDirectionMap[nextPose.dir] or Enum.EasingDirection.InOut)

			local finalCF = lastPose.cframe:Lerp(nextPose.cframe, easedAlpha)

			if lastPose.jtype == "Motor6D" then
				lastPose.joint.Transform = finalCF
			else
				lastPose.joint.Transform = finalCF
			end
		end
	end)

	return {
		Length = totalLength,
		Stop = function()
			isPlaying = false
			if conn then pcall(function() conn:Disconnect() end) end
		end,
		Play = function() startTime = os.clock() end
	}
end

local function CloneCharacter(char)
	char.Archivable = true
	local clone = char:Clone()
	char.Archivable = false
	return clone
end

-- ==================== PERFORM DROPKICK ====================
local function PerformDropkick(victimChar, originalSpeed, vfxList)
	if not character or not character.Parent then return end
	
	local hrp = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChild("Humanoid")
	if not hrp or not humanoid then return end

	loadstring(game:HttpGet("https://raw.githubusercontent.com/ian49972/smth/refs/heads/main/DropkickCam"))()

	local sound = Instance.new("Sound")
	sound.SoundId = getcustomasset("KJHIT.mp3")
	sound.Volume = 10
	sound.Parent = workspace
	sound:Play()

	hrp.Anchored = true

	local victimClone = CloneCharacter(victimChar)
	victimClone.Name = victimChar.Name .. "_DropkickClone"
	victimClone.Parent = workspace

	local victimHrp = victimClone:FindFirstChild("HumanoidRootPart")
	if victimHrp then
		victimHrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -10) * CFrame.Angles(0, math.rad(180), 0)
		local weld = Instance.new("WeldConstraint")
		weld.Part0 = hrp
		weld.Part1 = victimHrp
		weld.Parent = hrp
	end

	local playerAnim = PlayKeyframeSequence(character, DropkickHitKS, 1)
	local enemyAnim  = PlayKeyframeSequence(victimClone, DropkickEnemyKS, 1)

	playerAnim.Play()
	enemyAnim.Play()

	-- ==================== BigDashLine (at 5s) ====================
	local bigDash = nil
	if BigDashLineTemplate then
		task.delay(5, function()
			if not victimClone or not victimClone.Parent then return end
			bigDash = BigDashLineTemplate:Clone()
			bigDash.Parent = workspace
			
			local victimRoot = victimClone:FindFirstChild("HumanoidRootPart")
			if victimRoot then
				bigDash.CFrame = victimRoot.CFrame 
					* CFrame.new(0, 0, -10) 
					* CFrame.Angles(0, math.rad(180), 0)
			end
		end)
	end

	-- ==================== DropkickFrames GUI (at 9.8s) ====================
	if PersistentDropkickGui then
		task.delay(9.8, function()
			-- Reset all frames to hidden
			local frames = {}
			for i = 1, 16 do
				local frame = PersistentDropkickGui:FindFirstChild("Frame" .. i)
				if frame and frame:IsA("ImageLabel") then
					frame.Visible = false
					table.insert(frames, frame)
				end
			end
			
			PersistentDropkickGui.Enabled = true
			
			if #frames == 0 then 
				task.delay(5, function()
					PersistentDropkickGui.Enabled = false
				end)
				return 
			end
			
			-- Sequential playback
			for i, frame in ipairs(frames) do
				frame.Visible = true
				task.wait(0.15)
				if i < #frames then  -- Only hide if it's NOT the last frame
					frame.Visible = false
				end
			end
			
			-- Keep the last frame visible and hide GUI after 5 seconds
			task.delay(3, function()
				PersistentDropkickGui.Enabled = false
			end)
		end)
	end

	-- ==================== BeamScreen (at 9s) ====================
	task.delay(9, function()
		if not victimClone or not victimClone.Parent then return end
			
		if bigDash and bigDash.Parent then
			bigDash:Destroy()
		end

		local beamClone = BeamScreenTemplate:Clone()
		beamClone.Parent = workspace
			
		local victimRoot = victimClone:FindFirstChild("HumanoidRootPart")
		if victimRoot then
			beamClone.CFrame = victimRoot.CFrame 
				* CFrame.new(0, 0, 180) 
				* CFrame.Angles(math.rad(-50), math.rad(180), 0)
		end
		Debris:AddItem(beamClone, 7)
	end)

	-- Clean VFX
	if vfxList then
		for _, vfx in ipairs(vfxList) do
			if vfx and vfx.Parent then vfx:Destroy() end
		end
	end

	-- Clone deletes when enemy animation ends
	task.delay(enemyAnim.Length, function()
		if victimClone and victimClone.Parent then
			victimClone:Destroy()
		end
	end)

	-- Player cleanup when player animation ends
	task.delay(playerAnim.Length, function()
		if hrp then hrp.Anchored = false end
		if humanoid then humanoid.WalkSpeed = originalSpeed end
		
		pcall(function() playerAnim.Stop() end)
		pcall(function() enemyAnim.Stop() end)
		
		if humanoid and not humanoid:FindFirstChild("Animator") then
			Instance.new("Animator", humanoid)
		end
	end)
end

-- ==================== TOOL ACTIVATED ====================
tool.Activated:Connect(function()
	Cleanup()

	if not character or not character.Parent then return end
	local hrp = character:FindFirstChild("HumanoidRootPart")
	local humanoid = character:FindFirstChild("Humanoid")
	if not hrp or not humanoid then return end

	local originalSpeed = humanoid.WalkSpeed

	local animator = humanoid:FindFirstChild("Animator")
	if animator then animator:Destroy() end

	local startupSound = Instance.new("Sound")
	startupSound.SoundId = getcustomasset("KJSTART.mp3")
	startupSound.Volume = 1
	startupSound.Parent = workspace
	startupSound:Play()

	local startupAnim = PlayKeyframeSequence(character, StartupKS, 1)
	startupAnim.Play()

	humanoid.WalkSpeed = 0

	local faceConn = Connect(RunService.Heartbeat, function()
		if not hrp then return end
		local camera = workspace.CurrentCamera
		local lookDir = camera.CFrame.LookVector
		local flatLook = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
		if flatLook.Magnitude > 0.1 then
			hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + flatLook)
		end
	end)

	local bv = Instance.new("BodyVelocity")
	bv.Name = "DropkickVelocity"
	bv.MaxForce = Vector3.new(50000, 0, 50000)
	bv.Velocity = Vector3.new(0, 0, 0)
	bv.Parent = hrp

	local activeVFX = {}
	local dropkickTriggered = false

	task.delay(1.8, function()
		if dropkickTriggered then return end

		if SpeedVFX then
			local vfx1 = SpeedVFX:Clone()
			vfx1.Parent = character
			for _, weld in ipairs(vfx1:GetDescendants()) do
				if weld.Name == "Weld" and weld:IsA("Weld") then
					weld.Part0 = hrp
				end
			end
			if vfx1:IsA("BasePart") then vfx1.Anchored = false end
			table.insert(activeVFX, vfx1)
		end

		if SpeedVFX2 then
			local vfx2 = SpeedVFX2:Clone()
			vfx2.Parent = character
			for _, weld in ipairs(vfx2:GetDescendants()) do
				if weld.Name == "Weld" and weld:IsA("Weld") then
					weld.Part0 = hrp
				end
			end
			if vfx2:IsA("BasePart") then vfx2.Anchored = false end
			table.insert(activeVFX, vfx2)
		end

		local chargeConn = Connect(RunService.Heartbeat, function()
			if dropkickTriggered then return end
			local lookDir = hrp.CFrame.LookVector
			bv.Velocity = lookDir * 250
		end)

		local checkConn = Connect(RunService.Heartbeat, function()
			if dropkickTriggered then return end
			
			for _, p in ipairs(Players:GetPlayers()) do
				if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
					local dist = (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude
					if dist <= 10 then
						dropkickTriggered = true
						Cleanup()
						faceConn:Disconnect()
						
						startupSound:Stop()
						startupAnim.Stop()
						if bv and bv.Parent then bv:Destroy() end
						
						PerformDropkick(p.Character, originalSpeed, activeVFX)
						return
					end
				end
			end
		end)

		task.delay(4, function()
			if dropkickTriggered then return end
			dropkickTriggered = true
			Cleanup()
			faceConn:Disconnect()
			
			if bv and bv.Parent then bv:Destroy() end
			humanoid.WalkSpeed = originalSpeed
			
			for _, vfx in ipairs(activeVFX) do
				if vfx and vfx.Parent then vfx:Destroy() end
			end
			
			task.delay(1.1, function()
				startupSound:Stop()
				startupAnim.Stop()
				if humanoid and not humanoid:FindFirstChild("Animator") then
					Instance.new("Animator", humanoid)
				end
			end)
		end)
	end)
end)