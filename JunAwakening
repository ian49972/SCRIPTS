							bury:Play()
							bury.Completed:Connect(function()
								if rock and rock.Parent then rock:Destroy() end
							end)
						end
					end)
				end

				for i = 1, 16 do
					local angle = math.random() * math.pi * 2
					local radius = math.random(15, 70) / 10
					local offset = Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)

					local debris = Instance.new("Part")
					debris.Size = Vector3.new(math.random(5, 12)/10, math.random(4, 10)/10, math.random(5, 12)/10)
					debris.Material = groundMaterial
					debris.BrickColor = groundColor
					debris.Anchored = false
					debris.CanCollide = true
					debris.CFrame = CFrame.new(craterCenter + offset + Vector3.new(0, 1.2, 0))
					debris.Parent = workspace

					local bv = Instance.new("BodyVelocity")
					bv.MaxForce = Vector3.new(6000, 6000, 6000)
					bv.Velocity = Vector3.new(math.random(-22, 22), math.random(25, 42), math.random(-22, 22))
					bv.Parent = debris

					task.delay(0.55, function()
						if bv then bv:Destroy() end
					end)

					task.delay(6.5, function()
						if debris and debris.Parent then
							debris:Destroy()
						end
					end)
				end

				loadstring(game:HttpGet("https://raw.githubusercontent.com/ian49972/smth/refs/heads/main/ULTCam"))()
				humanoid.WalkSpeed = 16
			end
		end)
	end)

	task.wait(anim.Length)
	anim.Stop()

	stopFollow()
	if bv1Update then bv1Update:Disconnect() end

	Instance.new("Animator", humanoid)

	loadstring(game:HttpGet("https://raw.githubusercontent.com/ian49972/SCRIPTS/refs/heads/main/NMGB"))()
	loadstring(game:HttpGet("https://raw.githubusercontent.com/ian49972/SCRIPTS/refs/heads/main/PhantomSever"))()
	loadstring(game:HttpGet("https://raw.githubusercontent.com/ian49972/SCRIPTS/refs/heads/main/OneInchKillerPunch"))()
   loadstring(game:HttpGet("https://raw.githubusercontent.com/ian49972/SCRIPTS/refs/heads/main/CombatGods"))()
