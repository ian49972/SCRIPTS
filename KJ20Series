						for _, emitter in ipairs(att:GetChildren()) do
							if emitter:IsA("ParticleEmitter") then
								emitter:Emit(1)
							end
						end
					end
				end
			end
			local groundcrok = FineTemplate and FineTemplate:FindFirstChild("EmitBatch2", true) and FineTemplate.EmitBatch2:FindFirstChild("groundcrok")
			if groundcrok and groundcrok:IsA("ParticleEmitter") then
				groundcrok:Emit(1)
			end
		end)

		local bv = Instance.new("BodyVelocity")
		bv.Name = "KJVelocity"
		bv.MaxForce = Vector3.new(99999999, 0, 99999999)
		bv.Velocity = Vector3.new(0, 0, 0)
		bv.Parent = hrp

		local chargeConn = RunService.Heartbeat:Connect(function()
			if hrp then
				bv.Velocity = hrp.CFrame.LookVector * 10   -- Balanced speed
			end
		end)

		task.delay(1.9, function()
			if bv and bv.Parent then bv:Destroy() end
			if chargeConn then chargeConn:Disconnect() end
			if faceConn then faceConn:Disconnect() end
			humanoid.WalkSpeed = originalSpeed
          task.wait(1)
			altAnim.Stop()
			for _, v in activeVFX do if v and v.Parent then v:Destroy() end end
			if not humanoid:FindFirstChild("Animator") then Instance.new("Animator", humanoid) end
		end)
