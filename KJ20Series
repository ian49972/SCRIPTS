	local isMoving = humanoid.MoveDirection.Magnitude > 0.1

	local animator = humanoid:FindFirstChild("Animator")
	if animator then animator:Destroy() end

	humanoid.WalkSpeed = 0

	local activeVFX = {}
	local faceConn

	if not isMoving then
		local ultAnim = PlayKeyframeSequence(character, KJULTKS, 1)
		ultAnim.Play()

		local sound = Instance.new("Sound")
		sound.SoundId = getcustomasset("ULT.mp3")
		sound.Volume = 1
		sound.Parent = workspace
		sound:Play()

		for _, template in {FineTemplate, Fine2Template, KJTemplate} do
			if template then
				local clone = template:Clone()
				clone.Parent = workspace
				clone:PivotTo(hrp.CFrame)
				for _, weld in ipairs(clone:GetDescendants()) do
					if weld:IsA("Weld") or weld:IsA("ManualWeld") then
						weld.Part0 = hrp
					end
				end
				if clone:IsA("BasePart") then clone.Anchored = false end
				table.insert(activeVFX, clone)
			end
		end

		for _, vfx in activeVFX do
			for _, att in ipairs(vfx:GetDescendants()) do
				if att:IsA("Attachment") then
					for _, emitter in ipairs(att:GetChildren()) do
						if emitter:IsA("ParticleEmitter") then
							emitter:Emit(1)
						end
					end
				end
			end
		end

		local groundcrok = FineTemplate and FineTemplate:FindFirstChild("EmitBatch2", true) and FineTemplate.EmitBatch2:FindFirstChild("groundcrok")
		if groundcrok and groundcrok:IsA("ParticleEmitter") then
			groundcrok:Emit(1)
		end

		task.delay(2.5, function() CreateDialogue(parseTextToData("Fine.")) end)
		task.delay(4, function() CreateDialogue(parseTextToData("Come as close as you like.")) end)
		task.delay(6.3, function() CreateDialogue(parseTextToData("However...")) end)
		task.delay(7.6, function() CreateDialogue(parseTextToData("This is the last time!")) end)

		task.delay(8, function()
			for _, vfx in ipairs(activeVFX) do
				if vfx and vfx.Parent then
					for _, emitter in ipairs(vfx:GetDescendants()) do
						if emitter:IsA("ParticleEmitter") then emitter.Enabled = false end
					end
					local batch2 = vfx:FindFirstChild("EmitBatch2", true)
					if batch2 then
						for _, p in ipairs(batch2:GetChildren()) do
							if p:IsA("ParticleEmitter") and p.Name ~= "groundcrok" then
								p:Emit(1)
							end
						end
					end
				end
			end
		end)

		task.delay(ultAnim.Length, function()
			humanoid.WalkSpeed = originalSpeed
			ultAnim.Stop()
			for _, v in activeVFX do if v and v.Parent then v:Destroy() end end
			if not humanoid:FindFirstChild("Animator") then Instance.new("Animator", humanoid) end
		end)

	else
		local altAnim = PlayKeyframeSequence(character, KJALTKS, 1)
		altAnim.Play()

		local sound = Instance.new("Sound")
		sound.SoundId = getcustomasset("ULT2.mp3")
		sound.Volume = 1
		sound.Parent = workspace
		sound:Play()

		CreateDialogue(parseTextToData("I'm getting sick of this."))

		faceConn = RunService.Heartbeat:Connect(function()
			if not hrp then return end
			local camera = workspace.CurrentCamera
			local lookDir = camera.CFrame.LookVector
			local flatLook = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
			if flatLook.Magnitude > 0.1 then
				hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + flatLook)
			end
		end)

		local kjClone = KJTemplate and KJTemplate:Clone()
		if kjClone then
			kjClone.Parent = workspace
			kjClone:PivotTo(hrp.CFrame)
			for _, weld in ipairs(kjClone:GetDescendants()) do
				if weld:IsA("Weld") or weld:IsA("ManualWeld") then
					weld.Part0 = hrp
				end
			end
			if kjClone:IsA("BasePart") then kjClone.Anchored = false end
			table.insert(activeVFX, kjClone)
		end

		task.delay(2, function()
			if kjClone then
				for _, att in ipairs(kjClone:GetDescendants()) do
